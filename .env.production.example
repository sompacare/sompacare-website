# Sompacare Platform — PRODUCTION environment template
# Copy to your secrets manager / ECS task env / Vercel project settings
# NEVER commit real secrets. NEVER enable dev bypass flags in production.

# ─── Database & cache ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/sompacare_platform?schema=public&sslmode=require"
REDIS_URL="redis://ELASTICACHE_ENDPOINT:6379"

# ─── API ────────────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=production
CORS_ORIGINS="https://nurse.yourdomain.com,https://facility.yourdomain.com,https://recruiter.yourdomain.com,https://admin.yourdomain.com"
AUTH_ALLOW_DEV_TOKENS=false
GEOFENCE_DEV_BYPASS=false
PAYMENTS_DEV_BYPASS=false
CHECKR_DEV_BYPASS=false
RESUME_PARSER_DEV_BYPASS=false
AI_MATCHING_DEV_BYPASS=false
JOBS_DEV_BYPASS=false
SMS_DEV_BYPASS=false
PUSH_DEV_BYPASS=false
LOAD_TEST_MODE=false

# ─── Clerk ──────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY="sk_live_..."
CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ─── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION="us-east-1"
S3_BUCKET_DOCUMENTS="sompacare-documents-prod"

# ─── Payments (live) ────────────────────────────────────────────────────────
# See docs/stripe-live-setup.md for full go-live steps
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Register webhook: https://api.yourdomain.com/api/v1/payments/stripe/webhook
# Events: payment_intent.succeeded, account.updated, v2.core.account.updated

# ─── Notifications ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Sompacare <notifications@yourdomain.com>"
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ─── AI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Observability ──────────────────────────────────────────────────────────
METRICS_ENABLED=true
SENTRY_DSN="https://...@sentry.io/..."
MOBILE_BIOMETRIC_ENABLED=true

# ─── Portal URLs ────────────────────────────────────────────────────────────
NURSE_PORTAL_URL="https://nurse.yourdomain.com"
FACILITY_PORTAL_URL="https://facility.yourdomain.com"
RECRUITER_PORTAL_URL="https://recruiter.yourdomain.com"
ADMIN_PORTAL_URL="https://admin.yourdomain.com"
