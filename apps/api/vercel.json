{
  "installCommand": "cd ../.. && NPM_CONFIG_PRODUCTION=false npm install",
  "buildCommand": "cd ../.. && node scripts/vercel-build-api.mjs",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
