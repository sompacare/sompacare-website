# Sompacare Platform — copy to `.env.platform` at repo root
# Used by NestJS API, Prisma, and portal apps

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sompacare:sompacare_dev@localhost:5432/sompacare_platform?schema=public"

# ─── Redis (BullMQ, caching — Milestone 10) ─────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004"

# ─── Clerk Authentication (Milestone 2) ─────────────────────────────────────
# Get keys from https://dashboard.clerk.com
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Dev fallback: use Bearer dev_dev_nurse_rn when Clerk is not configured
AUTH_ALLOW_DEV_TOKENS=true
# Skip GPS geofence + shift-window checks in local dev (set false to test real geofence)
GEOFENCE_DEV_BYPASS=true
# Wallet/instant-pay without live Stripe when STRIPE_SECRET_KEY unset
PAYMENTS_DEV_BYPASS=true
CHECKR_DEV_BYPASS=true
CHECKR_API_KEY=""
CHECKR_WEBHOOK_SECRET=""
CHECKR_PACKAGE="tasker_standard"
RESUME_PARSER_DEV_BYPASS=true
AI_MATCHING_DEV_BYPASS=true
JOBS_DEV_BYPASS=true
SMS_DEV_BYPASS=true
PUSH_DEV_BYPASS=true

# ─── AWS S3 (document uploads — Milestone 7) ────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_DOCUMENTS="sompacare-documents-dev"

# Local filesystem storage (dev — used when S3 creds are unset)
STORAGE_LOCAL_ENABLED=true
STORAGE_LOCAL_PATH="./uploads"
API_PUBLIC_URL="http://localhost:4000/api/v1"

# Supabase careers resume sync (marketing bucket → platform storage)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
# When Supabase creds are unset, read resumes/{id}/... from STORAGE_LOCAL_PATH (dev only)
SUPABASE_RESUME_LOCAL_MIRROR=true

# ─── Stripe (payments — Milestone 5) ────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
# Auto-updated when you run: npm run stripe:listen
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Google Maps (shift map — Milestone 3) ──────────────────────────────────
GOOGLE_MAPS_API_KEY=""

# ─── Firebase (push notifications — Milestone 10) ───────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ─── OpenAI (AI matching — Milestone 9) ─────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
AI_MATCHING_DEV_BYPASS=true
RESUME_PARSER_DEV_BYPASS=true

# ─── Portal URLs ────────────────────────────────────────────────────────────
NURSE_PORTAL_URL="http://localhost:3001"
FACILITY_PORTAL_URL="http://localhost:3002"
RECRUITER_PORTAL_URL="http://localhost:3003"
ADMIN_PORTAL_URL="http://localhost:3004"

# Careers → recruiter pipeline ingest (marketing site → API)
CAREERS_INGEST_SECRET="dev-careers-ingest-secret"
PLATFORM_API_URL="http://localhost:4000/api/v1"
SITE_URL="https://sompacare.com"

# ─── Mobile (M12) ─────────────────────────────────────────────────────────
MOBILE_BIOMETRIC_ENABLED=true
# Get key from https://resend.com — emails log a warning when unset
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Sompacare <onboarding@resend.dev>"

# Nurse portal dev token fallback (matches seed user clerkId dev_nurse_rn)
NEXT_PUBLIC_NURSE_PORTAL_DEV_TOKEN="dev_nurse_rn"
NEXT_PUBLIC_RECRUITER_PORTAL_DEV_TOKEN="dev_recruiter"

# ─── Observability (M13) ────────────────────────────────────────────────────
METRICS_ENABLED=true
LOAD_TEST_MODE=false
# Set true when running k6 at high VUs (raises rate limit to 100k/min)
SENTRY_DSN=""
# Grafana local: http://localhost:3005 (admin / sompacare)
# Prometheus local: http://localhost:9090

# ─── Email notifications (M3 polish) ──────────────────────────────────────
