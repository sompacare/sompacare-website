# Resend — https://resend.com/api-keys

# sompacare.com must be verified at https://resend.com/domains

RESEND_API_KEY=re_your_api_key_here



# Verified sender on your domain (careers@ is used for hiring & onboarding)

RESEND_FROM_EMAIL=Sompacare <careers@sompacare.com>



# Optional: only if you still use onboarding@resend.dev during local testing

# RESEND_SANDBOX_INBOX=info@sompacare.com



# Email routing (v1)

INFO_TO_EMAIL=info@sompacare.com

STAFFING_TO_EMAIL=staffing@sompacare.com

CAREERS_TO_EMAIL=careers@sompacare.com



# Legacy fallback for contact form

CONTACT_TO_EMAIL=info@sompacare.com



# Supabase — https://supabase.com/dashboard → Project Settings → API

# URL: copy "Project URL" only (example: https://abcdefgh.supabase.co) — do NOT add /rest/v1

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Key: click Reveal on "service_role" under Project API keys — NOT publishable or anon

SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key



# Admin dashboard (/admin/login)

ADMIN_PASSWORD=choose-a-strong-password

ADMIN_SESSION_TOKEN=generate-a-long-random-string



# Optional link for the "Begin Onboarding" button in hire emails (defaults to /contact)
ONBOARDING_PORTAL_URL=https://sompacare.com/contact

# Careers → recruiter pipeline (marketing site forwards applications to platform API)
PLATFORM_API_URL=http://localhost:4000/api/v1
CAREERS_INGEST_SECRET=dev-careers-ingest-secret
SITE_URL=https://sompacare.com



# Stripe — https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_test_your_secret_key

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Webhook signing secret — https://dashboard.stripe.com/webhooks

# Endpoint URL: https://www.sompacare.com/api/stripe/webhook

STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret



# Optional: Postgres connection string for one-click admin DB setup
# Supabase → Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres



# Setup:

# 1. Run supabase/schema.sql in Supabase SQL Editor

# 3. Run supabase/payroll-migration.sql for payroll module
# 4. Run supabase/hire-orientation-migration.sql for hire & orientation details

# 3. Run supabase/admin-dashboard.sql for admin ops tables

# 4. Create Storage buckets: "application-files" (private), "business-documents" (private)

# 5. Add env vars above to .env.local and Vercel


