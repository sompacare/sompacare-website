{
  "name": "sompacare",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/clean.mjs && node scripts/dev.mjs",
    "dev:web": "node scripts/dev.mjs",
    "dev:api": "npm run dev --workspace=@sompacare/api",
    "dev:platform": "turbo dev --filter=@sompacare/api --filter=@sompacare/nurse-portal --filter=@sompacare/facility-portal --filter=@sompacare/recruiter-portal --filter=@sompacare/admin-portal",
    "dev:mobile": "turbo dev --filter=@sompacare/mobile-nurse --filter=@sompacare/mobile-facility",
    "test:mobile-shared": "npm run test --workspace=@sompacare/mobile-shared",
    "build": "next build",
    "build:platform": "turbo build --filter=@sompacare/api --filter=@sompacare/shared --filter=@sompacare/database",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "setup:admin": "node scripts/setup-admin-dashboard.mjs",
    "db:generate": "npm run db:generate --workspace=@sompacare/database",
    "db:migrate": "npm run db:migrate --workspace=@sompacare/database",
    "db:seed": "npm run db:seed --workspace=@sompacare/database",
    "db:seed:roles": "npm run db:seed:roles --workspace=@sompacare/database",
    "db:studio": "npm run db:studio --workspace=@sompacare/database",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:observability": "docker compose -f docker-compose.observability.yml up -d",
    "test:rbac": "npm run test --workspace=@sompacare/shared",
    "test:api": "npm run test --workspace=@sompacare/api",
    "loadtest:shifts": "k6 run loadtests/shift-search.k6.js",
    "test:launch": "node scripts/test-m14-launch.mjs",
    "stripe:install": "node scripts/stripe-install.mjs",
    "stripe:listen": "node scripts/stripe-listen.mjs"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/supabase-js": "^2.108.2",
    "framer-motion": "^12.40.0",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.14.0",
    "server-only": "^0.0.1",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.0",
    "pg": "^8.22.0",
    "tailwindcss": "^4",
    "turbo": "^2.5.4",
    "typescript": "^5"
  }
}
